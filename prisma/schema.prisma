generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CareerStage {
  student
  intern
  new_grad
  early_career_engineer
}

enum FocusPreference {
  projects
  work_experience
  both
}

enum WorkItemType {
  project
  experience
}

enum SourceType {
  manual_note
  github_repo
}

enum EvidenceItemType {
  manual_note_excerpt
  github_readme
  github_commit
  github_pull_request
  github_issue
  github_release
}

enum ClaimConfidence {
  low
  medium
  high
}

enum OwnershipClarity {
  unclear
  partial
  clear
}

enum VerificationStatus {
  draft
  approved
  flagged
  rejected
}

enum VisibilityLevel {
  private
  resume_safe
  linkedin_safe
  public_safe
}

enum ArtifactType {
  resume_bullets
  linkedin_experience
  project_summary
}

enum TargetAngle {
  general
  ai_ml
  data_engineering
  backend
  full_stack
}

enum ArtifactTone {
  concise
  technical
  recruiter_friendly
}

enum TagDimension {
  domain
  competency
  emphasis
  audience_fit
}

enum GenerationKind {
  claim_research
  claim_cluster_research
  claim_merge
  claim_verification
  highlight_generation
  highlight_verification
  artifact_retrieval
  artifact_generation
  evidence_clustering
}

enum GenerationStatus {
  success
  provider_error
  parse_error
  validation_error
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  careerStage     CareerStage?
  currentGoal     String?
  focusPreference FocusPreference?
  workItems       WorkItem[]
  artifacts       Artifact[]
  githubConnection GitHubConnection?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model WorkItem {
  id             String         @id @default(cuid())
  userId         String
  title          String
  type           WorkItemType
  description    String
  startDate      DateTime?
  endDate        DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources        Source[]
  evidenceItems  EvidenceItem[]
  highlights     Highlight[]
  artifacts      Artifact[]
  generationRuns GenerationRun[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Source {
  id            String         @id @default(cuid())
  workItemId    String
  type          SourceType
  label         String
  externalId    String?
  rawContent    String?
  metadata      Json?
  workItem      WorkItem       @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  evidenceItems EvidenceItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([workItemId, type, externalId])
}

model GitHubConnection {
  id                   String   @id @default(cuid())
  userId               String   @unique
  githubUserId         String   @unique
  login                String
  accessTokenEncrypted String
  scope                String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model EvidenceItem {
  id                String           @id @default(cuid())
  workItemId        String
  sourceId          String
  externalId        String
  type              EvidenceItemType
  title             String
  content           String
  searchText        String
  parentKind        String?
  parentKey         String?
  included          Boolean          @default(true)
  metadata          Json?
  workItem          WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  source            Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  highlightEvidence HighlightEvidence[]
  tags              EvidenceTag[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([sourceId, externalId])
  @@index([workItemId, included, updatedAt])
  @@index([workItemId, parentKind, parentKey])
}

model EvidenceTag {
  id             String       @id @default(cuid())
  evidenceItemId String
  dimension      TagDimension
  tag            String
  score          Float?
  evidenceItem   EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([evidenceItemId, dimension, tag])
  @@index([dimension, tag])
}

model Highlight {
  id                String             @id @default(cuid())
  workItemId        String
  text              String
  summary           String
  searchText        String
  confidence        ClaimConfidence
  ownershipClarity  OwnershipClarity
  sensitivityFlag   Boolean            @default(false)
  verificationStatus VerificationStatus
  visibility        VisibilityLevel
  risksSummary      String?
  missingInfo       String?
  rejectionReason   String?
  verificationNotes String?
  metadata          Json?
  workItem          WorkItem           @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  evidence          HighlightEvidence[]
  tags              HighlightTag[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("Claim")
}

model HighlightEvidence {
  id             String       @id @default(cuid())
  highlightId    String
  evidenceItemId String
  relevanceScore Float?
  highlight      Highlight    @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  evidenceItem   EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([highlightId, evidenceItemId])
}

model HighlightTag {
  id          String       @id @default(cuid())
  highlightId String
  dimension   TagDimension
  tag         String
  score       Float?
  highlight   Highlight    @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([highlightId, dimension, tag])
  @@index([dimension, tag])
}

model Artifact {
  id          String       @id @default(cuid())
  userId      String
  workItemId  String?
  type        ArtifactType
  targetAngle TargetAngle
  tone        ArtifactTone
  content     String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItem    WorkItem?    @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GenerationRun {
  id              String           @id @default(cuid())
  workItemId      String
  kind            GenerationKind
  status          GenerationStatus
  provider        String
  modelId         String
  inputSummary    Json
  rawOutput       String?
  parsedOutput    Json?
  validationErrors Json?
  resultRefs      Json?
  tokenUsage      Json?
  estimatedCostUsd Float?
  workItem        WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workItemId, kind, createdAt])
}
