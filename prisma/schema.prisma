generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CareerStage {
  student
  intern
  new_grad
  early_career_engineer
}

enum FocusPreference {
  projects
  work_experience
  both
}

enum WorkItemType {
  project
  experience
}

enum SourceType {
  manual_note
  github_repo
}

enum EvidenceItemType {
  manual_note_excerpt
  github_readme
  github_commit
  github_pull_request
  github_issue
  github_release
}

enum ClaimConfidence {
  low
  medium
  high
}

enum OwnershipClarity {
  unclear
  partial
  clear
}

enum VerificationStatus {
  draft
  approved
  flagged
  rejected
}

enum VisibilityLevel {
  private
  resume_safe
  linkedin_safe
  public_safe
}

enum ArtifactType {
  resume_bullets
  linkedin_experience
  project_summary
}

enum TargetAngle {
  general
  ai_ml
  data_engineering
  backend
  full_stack
}

enum ArtifactTone {
  concise
  technical
  recruiter_friendly
}

enum GenerationKind {
  claim_research
  claim_cluster_research
  claim_merge
  claim_verification
  artifact_generation
  evidence_clustering
}

enum GenerationStatus {
  success
  provider_error
  parse_error
  validation_error
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  careerStage     CareerStage?
  currentGoal     String?
  focusPreference FocusPreference?
  workItems       WorkItem[]
  artifacts       Artifact[]
  githubConnection GitHubConnection?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model WorkItem {
  id              String            @id @default(cuid())
  userId          String
  title           String
  type            WorkItemType
  description     String
  startDate       DateTime?
  endDate         DateTime?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources         Source[]
  evidenceItems   EvidenceItem[]
  evidenceClusters EvidenceCluster[]
  claims          Claim[]
  artifacts       Artifact[]
  generationRuns  GenerationRun[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Source {
  id           String         @id @default(cuid())
  workItemId   String
  type         SourceType
  label        String
  externalId   String?
  rawContent   String?
  metadata     Json?
  workItem     WorkItem       @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  evidenceItems EvidenceItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([workItemId, type, externalId])
}

model GitHubConnection {
  id                   String   @id @default(cuid())
  userId               String   @unique
  githubUserId         String   @unique
  login                String
  accessTokenEncrypted String
  scope                String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model EvidenceItem {
  id           String           @id @default(cuid())
  workItemId   String
  sourceId     String
  externalId   String
  type         EvidenceItemType
  title        String
  content      String
  included     Boolean          @default(true)
  metadata     Json?
  workItem     WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  source       Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  clusterItems EvidenceClusterItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([sourceId, externalId])
  @@index([workItemId, included, updatedAt])
}

model EvidenceCluster {
  id         String                @id @default(cuid())
  workItemId String
  title      String
  summary    String
  theme      String
  confidence ClaimConfidence
  metadata   Json?
  workItem   WorkItem              @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  items      EvidenceClusterItem[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([workItemId, updatedAt])
}

model EvidenceClusterItem {
  id            String          @id @default(cuid())
  clusterId     String
  evidenceItemId String
  relevanceScore Float?
  cluster       EvidenceCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  evidenceItem  EvidenceItem    @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())

  @@unique([clusterId, evidenceItemId])
}

model Claim {
  id                String              @id @default(cuid())
  workItemId        String
  text              String
  category          String?
  confidence        ClaimConfidence
  ownershipClarity  OwnershipClarity
  sensitivityFlag   Boolean             @default(false)
  verificationStatus VerificationStatus
  visibility        VisibilityLevel
  risksSummary      String?
  missingInfo       String?
  rejectionReason   String?
  workItem          WorkItem            @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  evidenceCard      EvidenceCard?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model EvidenceCard {
  id                String   @id @default(cuid())
  claimId           String   @unique
  evidenceSummary   String
  rationaleSummary  String
  sourceRefs        Json
  verificationNotes String?
  claim             Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Artifact {
  id          String       @id @default(cuid())
  userId      String
  workItemId  String?
  type        ArtifactType
  targetAngle TargetAngle
  tone        ArtifactTone
  content     String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItem    WorkItem?    @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model GenerationRun {
  id              String           @id @default(cuid())
  workItemId      String
  kind            GenerationKind
  status          GenerationStatus
  provider        String
  modelId         String
  inputSummary    Json
  rawOutput       String?
  parsedOutput    Json?
  validationErrors Json?
  resultRefs      Json?
  tokenUsage      Json?
  estimatedCostUsd Float?
  workItem        WorkItem         @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workItemId, kind, createdAt])
}
